# Supabase — copy this file to .env.local and fill in your project values
# Get these from: https://app.supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only — NEVER prefix with NEXT_PUBLIC_. Used by seed scripts only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Kit (ConvertKit) newsletter
# Get these from: https://app.kit.com → Settings → Developer → API
# Server-only — read inside /app/api/subscribe only, never prefix with NEXT_PUBLIC_.
CONVERTKIT_API_KEY=your_kit_api_key
CONVERTKIT_FORM_ID=your_kit_form_id

# Site URL used for canonical/OpenGraph URLs and the sitemap. Falls back to
# https://bohemoai.com when unset.
NEXT_PUBLIC_SITE_URL=your_site_url
